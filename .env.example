# ============================================================
#  Nous & Chill - variables d'environnement (frontend)
# ------------------------------------------------------------
#  Copier en `.env.local` et remplir les valeurs reelles.
#  Ne jamais committer le `.env.local`.
# ============================================================

# URL de base des webhooks n8n (sans slash final)
# Ex. cloud :     https://tonsubdomain.app.n8n.cloud/webhook
# Ex. self-host : https://n8n.tondomaine.com/webhook
VITE_N8N_BASE_URL=https://n8n.samuelrilos.com/webhook

# Cle API partagee entre le front et n8n.
# Long secret aleatoire (>= 32 chars). Genere-le avec :
#   openssl rand -hex 32
# La meme valeur doit etre configuree cote n8n sous SHARED_API_KEY.
VITE_N8N_API_KEY=replace-with-long-random-secret

# Date de fin de saison au format ISO (YYYY-MM-DD).
# Affichee cote UI ("verdict dans X jours") et utilisee par le cron
# n8n pour basculer `season_unlocked = true`.
VITE_SEASON_END_DATE=2025-06-30

# URL publique de l'app.
# Doit matcher le deploiement Cloudflare Pages.
VITE_APP_BASE_URL=https://nous-et-chill.pages.dev

# Codes d'acces locaux verifies directement dans le frontend.
# Attention: visibles dans le bundle apres build, donc adaptes a un prototype prive,
# pas a une securite publique forte.
VITE_CODE_SAMUEL=nerve
VITE_CODE_MATHILDE=mathilde
VITE_CODE_AMIS_SAMUEL=amis-samuel
VITE_CODE_AMIS_MATHILDE=amis-mathilde


# ============================================================
#  Variables cote n8n (a configurer dans l'UI n8n)
# ------------------------------------------------------------
#  Ces variables ne vont PAS dans le front. Elles sont listees
#  ici comme reference pour ne rien oublier au moment de
#  configurer ton instance n8n.
# ============================================================

# AIRTABLE_PAT=patXXXXXXXXXXXXXX.YYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYY
# AIRTABLE_BASE_ID=appXXXXXXXXXXXX
# Nom du champ Attachment dans la table Episodes pour les photos importees.
# Par defaut, le workflow utilise "cover_image".
# AIRTABLE_EPISODE_IMAGE_FIELD=cover_image
# APP_BASE_URL=https://nous-et-chill.pages.dev
# SHARED_API_KEY=<meme-valeur-que-VITE_N8N_API_KEY>
# SEASON_END_DATE=2025-06-30
# CODE_SAMUEL=<code-secret-du-groupe-samuel>
# CODE_MATHILDE=<code-secret-du-groupe-mathilde>
# CODE_AMIS_SAMUEL=<code-secret-des-amis-samuel>
# CODE_AMIS_MATHILDE=<code-secret-des-amis-mathilde>
# ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXX
