# ============================================================
#  Nous & Chill — variables d'environnement (frontend)
# ------------------------------------------------------------
#  Copier en `.env.local` et remplir les valeurs réelles.
#  Ne jamais committer le `.env.local`.
# ============================================================

# URL de base des webhooks n8n (sans slash final)
# Ex. cloud :     https://tonsubdomain.app.n8n.cloud/webhook
# Ex. self-host : https://n8n.tondomaine.com/webhook
VITE_N8N_BASE_URL=https://your-n8n-instance.com/webhook

# Clé API partagée entre le front et n8n.
# Long secret aléatoire (≥ 32 chars). Génère-le avec :
#   openssl rand -hex 32
# La même valeur doit être configurée côté n8n sous SHARED_API_KEY.
VITE_N8N_API_KEY=replace-with-long-random-secret

# Date de fin de saison au format ISO (YYYY-MM-DD).
# Affichée côté UI ("verdict dans X jours") et utilisée par le cron
# n8n pour basculer `season_unlocked = true`.
VITE_SEASON_END_DATE=2025-06-30

# URL publique de l'app (utilisée pour générer les magic links côté n8n).
# Doit matcher le déploiement Cloudflare Pages.
VITE_APP_BASE_URL=https://nous-et-chill.pages.dev


# ============================================================
#  Variables côté n8n (à configurer dans l'UI n8n)
# ------------------------------------------------------------
#  Ces variables ne vont PAS dans le front — elles sont listées
#  ici comme référence pour ne rien oublier au moment de
#  configurer ton instance n8n.
# ============================================================

# AIRTABLE_PAT=patXXXXXXXXXXXXXX.YYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYY
# AIRTABLE_BASE_ID=appXXXXXXXXXXXX
# RESEND_API_KEY=re_XXXXXXXXXXXXXXXX
# APP_BASE_URL=https://nous-et-chill.pages.dev
# SHARED_API_KEY=<même-valeur-que-VITE_N8N_API_KEY>
# SEASON_END_DATE=2025-06-30
# ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXX
